# Slack App Configuration (Required)
# Get these from https://api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_SIGNING_SECRET=your-signing-secret

# Claude Code Configuration (Optional)
# If not set, uses your logged-in claude CLI session (no API key needed!)
# ANTHROPIC_API_KEY=sk-ant-...

# Use system claude binary instead of SDK's bundled cli.js
# Set this to your claude CLI path (run `which claude` to find it)
CLAUDE_SYSTEM_BINARY=/path/to/claude

# Working Directory (Optional)
# Default project directory - bot uses this as fallback when no cwd is set
BASE_DIRECTORY=/path/to/your/projects

# Claude Settings (Optional)
# CLAUDE_MAX_TURNS=10

# Development
# DEBUG=true
